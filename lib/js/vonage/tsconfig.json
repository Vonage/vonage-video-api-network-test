{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": [
      "node",
      "@vonage/client-sdk-video",
      "@vonage/server-sdk"
    ],
    "baseUrl": ".",
    "outDir": "../../../dist/vonage",
    "rootDir": "../",
    "declarationDir": "../../../dist/vonage",

    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,

    "paths": {
      "@shared": ["../shared/index.ts"], 
      "@shared/*": ["../shared/*"]
    }
  },
  "files": [
    "src/index.ts",
    // "test/NetworkTest.spec.ts"
  ],
  "include": [
    "vonage/src/**/*.ts", 
    "shared/**/*.ts"
  ],
}